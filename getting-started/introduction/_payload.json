order radius, and animation.",[776,791,794],{"name":792,"type":793},"Tooltips","auto-placement, arrow, image",[283,795,796],{},"Positioned tooltips with title, description, image, and arrow. Auto-flips to stay in viewport.",[776,798,801],{"name":799,"type":800},"Navigation","buttons + keyboard",[283,802,803],{},"Built-in prev/next/finish/skip buttons and keyboard navigation with ArrowRight, ArrowLeft, and Escape.",[776,805,808],{"name":806,"type":807},"Skip feature","localStorage",[283,809,810],{},"\"Don't show again\" checkbox with persistent storage — the onboarding won't replay for returning users.",[776,812,814],{"name":113,"type":813},"single element spotlight",[283,815,816,817,820],{},"Spotlight a single element without a full tour using the ",[290,818,819],{},"highlight()"," shortcut.",[776,822,824],{"name":105,"type":823},"breakpoint overrides",[283,825,826],{},"Apply different component configs at different viewport widths via matchMedia breakpoints.",[776,828,831],{"name":829,"type":830},"Runtime updates","mergeConfig / setConfig",[283,832,833],{},"Patch or replace the entire config without unmounting.",[278,835,837],{"id":836},"bundle-size","Bundle size",[283,839,840,841,844],{},"The production bundle weighs under ",[766,842,843],{},"40 KB gzipped"," (JS + CSS combined). Zero runtime dependencies — nothing is loaded beyond the assets you provide.",[306,846,848],{"icon":847,"to":258},"i-lucide-arrow-right",[283,849,850,851,853],{},"Full breakdown by format in the ",[766,852,257],{}," reference.",[855,856,857],"style",{},"html pre.shiki code .spNyl, html code.shiki .spNyl{--shiki-light:#9C3EDA;--shiki-default:#C792EA;--shiki-dark:#C792EA}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .s7zQu, html code.shiki .s7zQu{--shiki-light:#39ADB5;--shiki-light-fo