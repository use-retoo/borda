1,325,326],{},"80+",[306,328,329,332],{},[321,330,331],{},"Firefox",[321,333,326],{},[306,335,336,339],{},[321,337,338],{},"Safari",[321,340,341],{},"14+",[306,343,344,347],{},[321,345,346],{},"Edge",[321,348,349],{},"80+ (Chromium-based)",[306,351,352,355],{},[321,353,354],{},"Opera",[321,356,357],{},"67+",[306,359,360,363],{},[321,361,362],{},"Samsung Internet",[321,364,365],{},"13+",[295,367,369],{"id":368},"required-web-apis","Required Web APIs",[278,371,372],{},"Borda relies on the following browser APIs at runtime:",[300,374,375,385],{},[303,376,377],{},[306,378,379,382],{},[309,380,381],{},"API",[309,383,384],{},"Used for",[316,386,387,396,406,420,430],{},[306,388,389,393],{},[321,390,391],{},[282,392,292],{},[321,394,395],{},"Detecting target element visibility for spotlight positioning",[306,397,398,403],{},[321,399,400],{},[282,401,402],{},"ResizeObserver",[321,404,405],{},"Adapting tooltip and overlay layout when the container resizes",[306,407,408,413],{},[321,409,410],{},[282,411,412],{},"customElements",[321,414,415,416,419],{},"Custom Element registration (",[282,417,418],{},"defineBordaElement()",")",[306,421,422,427],{},[321,423,424],{},[282,425,426],{},"matchMedia",[321,428,429],{},"Responsive breakpoint detection",[306,431,432,437],{},[321,433,434],{},[282,435,436],{},"CSS Custom Properties",[321,438,439],{},"Theming and dynamic style overrides",[278,441,442],{},"All listed APIs are supported in the browsers above. If you need to support older browsers, include the corresponding polyfills before loading Borda.",[295,444,446],{"id":445},"internet-explorer","Internet Explorer",[278,448,449],{},"Internet Explorer is not supported. Borda uses ES Module syntax, CSS custom properties, and modern DOM APIs that have no IE equivalents.",[295,451,453],{"id":452},"mobile-browsers","Mobile browsers",[278,455,456,457,460],{},"Borda works on mobile Chrome, Safari (iOS), Firefox, and Samsung Internet. The spotlight overlay, tooltip positioning, and keyboard navigation all work on touch devices. Keyboard navigation is optional and can be disabled via ",[282,458,459],{},"tour.hasKeyboardControl: false",".",[295,462,464],{"id":463},"nodejs","Node.js",[278,466,467,468,471],{},"For SSR or prerendering scenarios, Borda requires Node.js 16.0 or later. The CommonJS build is available for ",[282,469,470],{},"require()"," usage. Note that actual tour rendering requires a browser DOM — the Node.js build is intended for server-side mounting logic and config preparation.",{"title":473,"searchDepth":474,"depth":475,"links":476},"",1,2,[477,478,479,480,481],{"id":297,"depth":475,"text":298},{"id":368,"depth":475,"text":369},{"id":445,"depth":475,"text":446},{"id":452,"depth":475,"text":453},{"id":463,"depth":475,"text":464},"Supported browsers, required polyfills, and compatibility notes.","md",null,{},true,{"title":253,"description":482},"mIekhHk8UQjyWBMP-hWpY7E03UugyLyXOXBdhQh9XCM",[490,492],{"title":249,"path":250,"stem":251,"description":491,"children":-1},"Available build formats — ES Module, UMD, CommonJS, and their minified variants.",{"title":257,"path":258,"stem":259,"description":493,"children":-1},"Size of each distribution format and tree-shaking capabilities.",1782087446559]