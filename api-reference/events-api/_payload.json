ubscribes after first call",[298,332,333,338],{},[313,334,335],{},[282,336,337],{},"off(eventName, handler)",[313,339,340],{},"Unsubscribe a specific handler",[298,342,343,348],{},[313,344,345],{},[282,346,347],{},"emit\u003CT>(eventName, data?)",[313,349,350],{},"Emit an event with optional data",[298,352,353,358],{},[313,354,355],{},[282,356,357],{},"remove(eventName)",[313,359,360],{},"Remove all handlers for a specific event",[298,362,363,368],{},[313,364,365],{},[282,366,367],{},"clear()",[313,369,370],{},"Remove all handlers for all events",[287,372,193],{"id":373},"usage",[375,376,381],"pre",{"className":377,"code":378,"language":379,"meta":380,"style":380},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","import { BordaEvent } from '@retoo/borda';\n\n// Subscribe\ninstance.api.events.on(BordaEvent.ON_TOUR_START, () => {\n  console.log('Tour started');\n});\n\n// Unsubscribe\nconst handler = () => console.log('finished');\ninstance.api.events.on(BordaEvent.ON_TOUR_FINISH, handler);\ninstance.api.events.off(BordaEvent.ON_TOUR_FINISH, handler);\n\n// One-time subscription\ninstance.api.events.once(BordaEvent.ON_TOUR_CLOSE, () => {\n  console.log('Tour closed (once)');\n});\n","ts","",[282,382,383,419,426,433,476,503,513,518,524,560,591,621,626,632,665,687],{"__ignoreMap":380},[384,385,388,392,396,400,403,406,409,413,416],"span",{"class":386,"line":387},"line",1,[384,389,391],{"class":390},"s7zQu","import",[384,393,395],{"class":394},"sMK4o"," {",[384,397,399],{"class":398},"sTEyZ"," BordaEvent",[384,401,402],{"class":394}," }",[384,404,405],{"class":390}," from",[384,407,408],{"class":394}," '",[384,410,412],{"class":411},"sfazB","@retoo/borda",[384,414,415],{"class":394},"'",[384,417,418],{"class":394},";\n",[384,420,422],{"class":386,"line":421},2,[384,423,425],{"emptyLinePlaceholder":424},true,"\n",[384,427,429],{"class":386,"line":428},3,[384,430,432],{"class":431},"sHwdD","// Subscribe\n",[384,434,436,439,441,